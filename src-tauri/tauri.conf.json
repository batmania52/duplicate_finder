{
  "productName": "dup-finder",
  "version": "1.0.0",
  "identifier": "com.utils-project.dup-finder",
  "build": {
    "frontendDist": "../static"
  },
  "app": {
    "windows": [
      {
        "title": "Dup Finder",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "url": "http://127.0.0.1:8765/"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "dialog": {}
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
