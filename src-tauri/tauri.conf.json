{
  "productName": "dup-finder",
  "version": "1.0.0",
  "identifier": "com.utils-project.dup-finder",
  "build": {
    "frontendDist": "../static"
  },
  "app": {
    "windows": [
      {
        "title": "Dup Finder",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "url": "http://127.0.0.1:8765/"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png"
    ],
    "resources": {
      "ffmpeg-dlls/avcodec-62.dll": ".",
      "ffmpeg-dlls/avdevice-62.dll": ".",
      "ffmpeg-dlls/avfilter-11.dll": ".",
      "ffmpeg-dlls/avformat-62.dll": ".",
      "ffmpeg-dlls/avutil-60.dll": ".",
      "ffmpeg-dlls/swresample-6.dll": ".",
      "ffmpeg-dlls/swscale-9.dll": "."
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
