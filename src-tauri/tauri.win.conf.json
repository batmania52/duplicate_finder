{
  "productName": "dup-finder",
  "version": "1.0.0",
  "identifier": "com.utils-project.dup-finder",
  "build": {
    "frontendDist": "../static"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "nsis"
    ],
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png"
    ],
    "resources": {
      "dlls/*": ""
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
